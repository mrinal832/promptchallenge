{
  "openapi": "3.0.0",
  "info": {
    "title": "TripSync AI API",
    "version": "1.0.0",
    "description": "API documentation for the TripSync AI travel planning engine."
  },
  "servers": [
    {
      "url": "http://localhost:5000/api"
    }
  ],
  "paths": {
    "/users/login": {
      "post": {
        "summary": "Authenticate user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful login" }
        }
      }
    },
    "/trips": {
      "post": {
        "summary": "Create a new trip",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Trip created" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
